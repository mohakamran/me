/* ===== CSS VARIABLES (DARK PREMIUM) ===== */
:root {
    --primary: #4f46e5; /* Vivid Indigo */
    --secondary: #0ea5e9; /* Light Sky Blue */
    --accent: #f43f5e; /* Rose / Coral */
    --accent-vibrant: #ec4899;
    
    --bg-main: #ffffff; /* Pure White */
    --bg-card: rgba(255, 255, 255, 0.8); /* Glassmorphism on light */
    --bg-nav: rgba(255, 255, 255, 0.95);
    --bg-glass-hover: rgba(0, 0, 0, 0.04);
    
    --text-main: #0f172a; /* Slate 900 */
    --text-muted: #475569; /* Slate 600 */
    
    --border-color: rgba(0, 0, 0, 0.08); /* Light border */
    --border-hover: rgba(79, 70, 229, 0.3); /* Indigo border */
    --shadow-color: rgba(0, 0, 0, 0.05);
    
    --gradient-1: #ffffff;
    --gradient-2: #f1f5f9;
    --gradient-3: #e2e8f0;
    --gradient-vibrant: linear-gradient(135deg, #4f46e5, #f43f5e);
    
    --particle: rgba(79, 70, 229, 0.1);
    
    --code-bg: rgba(0, 0, 0, 0.04);
}


/* ===== BASE STYLES ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Outfit', sans-serif;
}

body {
    background-color: var(--bg-main);
    color: var(--text-main);
    overflow-x: hidden;
    padding-top: 80px;
}

.container-custom {
    max-width: 70%;
    margin: 0 auto;
    padding: 0 1rem;
}

/* ===== CUSTOM SCROLLBAR ===== */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: var(--gradient-1);
}

::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 4px;
}

/* ===== ANIMATED BACKGROUND ===== */
.gradient-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    background: linear-gradient(-45deg, var(--gradient-1), var(--gradient-2), var(--gradient-1), var(--gradient-3));
    background-size: 400% 400%;
    animation: gradient 15s ease infinite;
}

@keyframes gradient {
    0% {
        background-position: 0% 50%;
    }
    50% {
        background-position: 100% 50%;
    }
    100% {
        background-position: 0% 50%;
    }
}

/* ===== FLOATING PARTICLES ===== */
.particles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
}

.particle {
    position: absolute;
    border-radius: 50%;
    background: var(--particle);
    animation: float 20s infinite linear;
}

@keyframes float {
    0% {
        transform: translateY(0) translateX(0);
        opacity: 0;
    }
    10% {
        opacity: 1;
    }
    90% {
        opacity: 1;
    }
    100% {
        transform: translateY(-100vh) translateX(100px);
        opacity: 0;
    }
}

/* ===== GLASS MORPHISM ===== */
.glass {
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border-color);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
}

.glass-vibrant {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.02), 0 10px 40px rgba(0, 0, 0, 0.4);
}

/* ===== NEON GLOW TEXT ===== */
.glow-text {
    color: var(--text-main);
    text-shadow: 0 0 10px rgba(14, 165, 233, 0.5), 0 0 20px rgba(14, 165, 233, 0.3);
}

.glow-text-secondary {
    color: var(--text-main);
    text-shadow: 0 0 10px rgba(20, 184, 166, 0.5), 0 0 20px rgba(20, 184, 166, 0.3);
}

/* ===== GRADIENT TEXT ===== */
.gradient-text {
    background: linear-gradient(90deg, var(--primary), var(--accent), var(--accent-vibrant));
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradient-text 3s ease infinite;
}

@keyframes gradient-text {
    0% {
        background-position: 0% 50%;
    }
    50% {
        background-position: 100% 50%;
    }
    100% {
        background-position: 0% 50%;
    }
}

/* ===== NAVBAR STYLES ===== */
.navbar {
    background: var(--bg-nav) !important;
    backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15) !important;
    box-shadow: 0 4px 30px var(--shadow-color) !important;
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 9999 !important;
    transform: translateZ(0) !important;
    will-change: transform;
    transition: background 0.4s ease, box-shadow 0.4s ease, transform 0.4s ease;
}

.nav-link {
    position: relative;
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.3s ease;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    transition: all 0.3s ease;
    transform: translateX(-50%);
}

.nav-link:hover::after,
.nav-link.active::after {
    width: 80%;
}

.nav-link:hover {
    background: var(--bg-glass-hover);
    transform: translateY(-2px);
}

.lang-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    border: 1px solid var(--border-color);
    padding: 8px 16px;
    border-radius: 6px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
}

.lang-btn:hover {
    transform: translateY(-1px);
    background: var(--border-color);
}

.mobile-nav-item {
    transition: all 0.3s ease;
    border-left: 3px solid transparent;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    text-decoration: none;
}

.mobile-nav-item:hover {
    border-left-color: var(--primary);
    background: var(--bg-glass-hover);
}

/* ===== MOBILE HAMBURGER MENU FIXES ===== */
#menu-toggle {
    transition: all 0.3s ease;
}

#menu-toggle:hover {
    background: var(--border-color);
    transform: scale(1.05);
}

/* Ensure mobile layout is clean */
@media (max-width: 1024px) {
    .navbar .flex.items-center.justify-between {
        flex-wrap: nowrap;
    }
    
    /* Language buttons on mobile */
    .lg\\:hidden.flex.items-center.space-x-1 {
        flex-shrink: 0;
    }
    
    /* Hamburger menu on mobile */
    .lg\\:hidden.p-2 {
        flex-shrink: 0;
    }
}

/* Mobile menu animations */
#mobile-menu {
    transition: all 0.3s ease-in-out;
}

#mobile-menu.hidden {
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
}

#mobile-menu:not(.hidden) {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
}

/* ===== SECTION ANIMATIONS ===== */
.section-hidden {
    opacity: 0;
    transform: translateY(50px) scale(0.95);
    filter: blur(10px);
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1), transform 1.2s cubic-bezier(0.22, 1, 0.36, 1), filter 1.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.section-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
}

/* ===== HERO SECTION ===== */
#home {
    padding-top: 0 !important;
    margin-top: 0 !important;
    min-height: calc(100vh - 80px) !important;
    display: flex;
    align-items: center;
}

.hero-badge {
    background: linear-gradient(135deg, rgba(20, 184, 166, 0.2), rgba(14, 165, 233, 0.2));
    border: 1px solid rgba(20, 184, 166, 0.3);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
}

.typewriter-container {
    min-height: 1.5em;
    display: flex;
    align-items: center;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--secondary);
}

@media (min-width: 640px) {
    .typewriter-container {
        font-size: 1.875rem;
        justify-content: flex-start;
    }
}

/* Floating animation */
@keyframes float-element {
    0%, 100% {
        transform: translateY(0px) rotate(0deg);
    }
    33% {
        transform: translateY(-10px) rotate(5deg);
    }
    66% {
        transform: translateY(5px) rotate(-5deg);
    }
}

.floating-element {
    animation: float-element 3s ease-in-out infinite;
}

/* Enhanced Tech Icons */
.tech-icon {
    animation: float-element 4s ease-in-out infinite;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    z-index: 10;
}

.tech-icon:hover {
    transform: scale(1.2) rotate(360deg);
    box-shadow: 0 0 30px currentColor;
}

.tech-icon-1 { animation-delay: 0s; }
.tech-icon-2 { animation-delay: 0.8s; }
.tech-icon-3 { animation-delay: 1.6s; }
.tech-icon-4 { animation-delay: 2.4s; }
.tech-icon-5 { animation-delay: 3.2s; }
.tech-icon-6 { animation-delay: 4s; }

/* Creative card styles */
.creative-card {
    position: relative;
    overflow: hidden;
}

.creative-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(45deg, transparent, var(--border-color), transparent);
    transform: rotate(45deg);
    transition: all 0.6s;
    opacity: 0;
}

.creative-card:hover::before {
    opacity: 1;
    animation: shine 1.5s;
}

@keyframes shine {
    0% {
        transform: translateX(-100%) translateY(-100%) rotate(45deg);
    }
    100% {
        transform: translateX(100%) translateY(100%) rotate(45deg);
    }
}

/* ===== SKILLS SECTION ===== */
.skill-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1rem;
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    min-height: 140px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.skill-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
    transition: all 0.6s;
}

.skill-card:hover::before {
    left: 100%;
}

.skill-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    border-color: var(--border-hover);
}

.skill-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.75rem;
    border: 2px solid;
    transition: all 0.3s ease;
}

.skill-card:hover .skill-icon {
    transform: scale(1.1) rotate(5deg);
}

.skill-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    line-height: 1.2;
}

.skill-level {
    width: 100%;
    height: 4px;
    background: var(--border-color);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 0.25rem;
}

.skill-progress {
    height: 100%;
    border-radius: 2px;
    width: 0;
    transition: width 1.5s ease-in-out;
    position: relative;
}

.skill-progress::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    animation: shimmer 2s infinite;
}

@keyframes shimmer {
    0% {
        transform: translateX(-100%);
    }
    100% {
        transform: translateX(100%);
    }
}

.skill-percent {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
}

/* ===== TIMELINE SECTION ===== */
.timeline-item {
    position: relative;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.timeline-item.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.timeline-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.timeline-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--bg-glass-hover), transparent);
    transition: all 0.6s;
}

.timeline-card:hover::before {
    left: 100%;
}

.timeline-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    border-color: var(--border-hover);
}

.timeline-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    border: 2px solid;
    transition: all 0.3s ease;
}

.timeline-card:hover .timeline-icon {
    transform: scale(1.1) rotate(5deg);
}

.timeline-content {
    position: relative;
}

.timeline-date {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: var(--text-main);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
}

.timeline-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    line-height: 1.3;
}

.timeline-subtitle {
    font-size: 1rem;
    color: var(--teal-400);
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-style: italic;
}

.timeline-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
}

.timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.timeline-tag {
    background: var(--border-color);
    color: var(--text-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.timeline-card:hover .timeline-tag {
    background: rgba(255, 255, 255, 0.15);
    color: var(--text-main);
}

/* ===== CERTIFICATIONS SECTION ===== */
.certification-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.certification-card.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.certification-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--bg-glass-hover), transparent);
    transition: all 0.6s;
}

.certification-card:hover::before {
    left: 100%;
}

.certification-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    border-color: var(--border-hover);
}

.certification-badge {
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    background: var(--border-color);
    border: 2px solid var(--border-hover);
    transition: all 0.3s ease;
}

.certification-card:hover .certification-badge {
    transform: scale(1.1) rotate(5deg);
    background: rgba(255, 255, 255, 0.15);
}

.certification-content {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.certification-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    line-height: 1.3;
}

.certification-issuer {
    font-size: 0.9rem;
    color: var(--teal-400);
    font-weight: 600;
    margin-bottom: 0.25rem;
}

.certification-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    font-weight: 500;
}

.certification-description {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
}

.certification-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.skill-tag {
    background: var(--border-color);
    color: var(--text-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.certification-card:hover .skill-tag {
    background: rgba(255, 255, 255, 0.15);
    color: var(--text-main);
}

.certification-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--teal-400);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: auto;
}

.certification-link:hover {
    color: var(--teal-300);
}

/* ===== PORTFOLIO SECTION ===== */
.filter-btn {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
    cursor: pointer;
}

.filter-btn.active {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-color: transparent;
}

.filter-btn:hover:not(.active) {
    background: var(--border-color);
    border-color: var(--border-hover);
}

.portfolio-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
}

.portfolio-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    border-color: var(--border-hover);
}

.portfolio-image-container {
    position: relative;
    overflow: hidden;
    height: 200px;
}

.portfolio-image {
    width: 100%;
    height: 100%;
    background: var(--bg-glass-hover);
}

.image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.portfolio-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.3s ease;
}

.portfolio-card:hover .portfolio-overlay {
    opacity: 1;
}

.portfolio-actions {
    display: flex;
    gap: 1rem;
}

.portfolio-btn {
    width: 3rem;
    height: 3rem;
    background: var(--border-color);
    border: 1px solid var(--border-hover);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-main);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
}

.portfolio-btn:hover {
    background: var(--border-hover);
    transform: scale(1.1);
}

.portfolio-btn.coming-soon {
    background: var(--bg-glass-hover);
    color: var(--text-muted);
    cursor: not-allowed;
}

.portfolio-content {
    padding: 1.5rem;
}

.portfolio-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    line-height: 1.3;
}

.portfolio-description {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
}

.portfolio-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.portfolio-tag {
    background: var(--border-color);
    color: var(--text-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--border-color);
}

.portfolio-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.portfolio-item.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.portfolio-item.hidden {
    display: none;
}

/* ===== SERVICES SECTION ===== */
.service-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 2rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.service-card.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--bg-glass-hover), transparent);
    transition: all 0.6s;
}

.service-card:hover::before {
    left: 100%;
}

.service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    border-color: var(--border-hover);
}

.service-icon {
    margin-bottom: 1.5rem;
    text-align: center;
}

.icon-container {
    width: 5rem;
    height: 5rem;
    border-radius: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    border: 2px solid;
    transition: all 0.3s ease;
}

.service-card:hover .icon-container {
    transform: scale(1.1) rotate(5deg);
    background: var(--border-color);
}

.service-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 1rem;
    text-align: center;
    line-height: 1.3;
}

.service-description {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    text-align: center;
    flex: 1;
}

.service-features {
    margin-bottom: 1.5rem;
    
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
}

.feature-item span {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
}

.service-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    justify-content: center;
}

.tech-tag {
    background: var(--border-color);
    color: var(--text-muted);
    padding: 0.375rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.service-card:hover .tech-tag {
    background: rgba(255, 255, 255, 0.15);
    color: var(--text-main);
    transform: translateY(-2px);
}

.service-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: var(--text-main);
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: auto;
    text-decoration: none;
}

.service-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
}

/* ===== GALLERY SECTION ===== */
.gallery-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
}

.gallery-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    border-color: var(--border-hover);
}

.gallery-image-container {
    position: relative;
    overflow: hidden;
    height: 250px;
}

.gallery-image {
    width: 100%;
    height: 100%;
    background: var(--bg-glass-hover);
}

.gallery-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.9));
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    opacity: 0;
    transition: all 0.3s ease;
}

.gallery-card:hover .gallery-overlay {
    opacity: 1;
}

.gallery-content {
    flex: 1;
}

.gallery-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    line-height: 1.3;
}

.gallery-description {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
}

.gallery-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.gallery-tag {
    background: var(--border-color);
    color: var(--text-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--border-color);
}

.gallery-actions {
    display: flex;
    justify-content: flex-end;
}

.gallery-btn {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--border-color);
    border: 1px solid var(--border-hover);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-main);
    cursor: pointer;
    transition: all 0.3s ease;
}

.gallery-btn:hover {
    background: var(--border-hover);
    transform: scale(1.1);
}

.gallery-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.gallery-item.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.gallery-item.hidden {
    display: none;
}

/* Lightbox Styles */
#lightbox {
    backdrop-filter: blur(10px);
}

.lightbox-content {
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid var(--border-hover);
}

/* ===== CONTACT SECTION ===== */
.contact-card {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.contact-card.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.contact-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    border-color: var(--border-hover);
}

.contact-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--border-color);
    border: 1px solid var(--border-hover);
    flex-shrink: 0;
}

.contact-content {
    flex: 1;
}

.contact-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.5rem;
}

.contact-info {
    font-size: 1rem;
    color: var(--teal-400);
    font-weight: 500;
    margin-bottom: 0.5rem;
}

.contact-subinfo {
    font-size: 0.875rem;
    color: var(--text-muted);
}

.contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--teal-400);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.3s ease;
}

.contact-link:hover {
    color: var(--teal-300);
    gap: 0.75rem;
}

.social-links {
    display: flex;
    gap: 0.75rem;
}

.social-link {
    width: 2.0rem;
    height: 2.0rem;
    background: var(--border-color);
    border: 1px solid var(--border-hover);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
}

.social-link:hover {
    background: var(--border-hover);
    color: var(--text-main);
    transform: translateY(-2px);
}

/* Contact Form Styles */
.contact-form-container {
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 2rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.contact-form-container.animate-in {
    opacity: 1;
    transform: translateY(0);
}

.form-group {
    margin-bottom: 1.5rem;
}

.form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.5rem;
}

.form-input,
.form-textarea {
    width: 100%;
    background: var(--bg-glass-hover);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    color: var(--text-main);
    font-size: 0.875rem;
    transition: all 0.3s ease;
}

.form-input::placeholder,
.form-textarea::placeholder {
    color: var(--text-muted);
}

.form-input:focus,
.form-textarea:focus {
    outline: none;
    border-color: var(--teal-400);
    background: rgba(255, 255, 255, 0.08);
}

.form-textarea {
    resize: vertical;
    min-height: 120px;
}

.submit-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: var(--text-main);
    font-weight: 600;
    padding: 1rem 2rem;
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    position: relative;
}

.submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
}

.submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
}

.submit-loader {
    position: absolute;
}

.hidden {
    display: none;
}

/* ===== FOOTER STYLES ===== */
.footer-btn {
    display: inline-flex;
    align-items: center;
    background: var(--border-color);
    color: var(--text-muted);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid var(--border-color);
}

.footer-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: var(--text-main);
    transform: translateY(-2px);
}

.footer-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.3s ease;
}

.footer-link:hover {
    color: var(--text-main);
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 1024px) {
    .timeline-card {
        margin: 0 auto;
        max-width: 400px;
    }

    .timeline-card-left,
    .timeline-card-right {
        margin: 0 auto 2rem;
    }
}

@media (max-width: 768px) {
    .skill-card {
        padding: 0.75rem;
        min-height: 120px;
    }

    .skill-icon {
        width: 2.5rem;
        height: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .skill-name {
        font-size: 0.8rem;
    }

    .skill-percent {
        font-size: 0.7rem;
    }

    .timeline-card {
        padding: 1.25rem;
    }

    .timeline-title {
        font-size: 1.1rem;
    }

    .timeline-subtitle {
        font-size: 0.9rem;
    }

    .timeline-description {
        font-size: 0.85rem;
    }

    .timeline-icon {
        width: 2.5rem;
        height: 2.5rem;
        margin-bottom: 0.75rem;
    }

    .certification-card {
        padding: 1.25rem;
    }

    .certification-badge {
        width: 3.5rem;
        height: 3.5rem;
        margin-bottom: 0.75rem;
    }

    .certification-title {
        font-size: 1rem;
    }

    .certification-description {
        font-size: 0.85rem;
    }

    .portfolio-image-container {
        height: 180px;
    }

    .portfolio-content {
        padding: 1.25rem;
    }

    .portfolio-title {
        font-size: 1rem;
    }

    .service-card {
        padding: 1.5rem;
    }

    .icon-container {
        width: 4rem;
        height: 4rem;
    }

    .service-title {
        font-size: 1.25rem;
    }

    .service-description {
        font-size: 0.9rem;
    }

    .gallery-image-container {
        height: 200px;
    }

    .gallery-overlay {
        padding: 1rem;
    }

    .gallery-title {
        font-size: 1rem;
    }

    .contact-card {
        padding: 1.25rem;
    }

    .contact-form-container {
        padding: 1.5rem;
    }

    .contact-icon {
        width: 2.5rem;
        height: 2.5rem;
    }
}

@media (max-width: 640px) {
    .grid-cols-3 {
        grid-template-columns: repeat(2, 1fr);
    }

    .grid-cols-1 {
        grid-template-columns: 1fr;
    }

    .filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
    }

    .portfolio-image-container {
        height: 180px;
    }

    .service-card {
        padding: 1.25rem;
    }

    .gallery-image-container {
        height: 180px;
    }

    .contact-card {
        flex-direction: column;
        text-align: center;
    }

    .contact-icon {
        margin: 0 auto;
    }
}

@media (max-width: 480px) {
    .grid-cols-3 {
        grid-template-columns: repeat(2, 1fr);
    }
}


/* ===== FLAG ICONS ===== */
.fi {
    border-radius: 1px;
    box-shadow: 0 0 1px rgba(0, 0, 0, 0.5);
}

.fi-us {
    background-image: url('data:image/svg+xml;base64,');
}

.fi-jp {
    background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAxMSA3Ij48cGF0aCBmaWxsPSIjZmZmIiBkPSJNMCAwaDExdjdIMHoiLz48cGF0aCBmaWxsPSIjYmMwMDJkIiBkPSJNNS41IDMuNWExLjUgMS41IDAgMSAwIDAgMyAxLjUgMS41IDAgMCAwIDAtM3oiLz48L3N2Zz4=');
}

.fis {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: inline-block;
    width: 1em;
    height: 0.75em;
    vertical-align: -0.1em;
}

/* Language Switcher Active States */
.lang-btn.active {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-color: transparent;
    color: var(--text-main);
}

.lang-btn:not(.active) {
    background: var(--border-color);
    border-color: var(--border-hover);
}

/* Services Section Styles Refined */
.service-card {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 1.5rem;
    padding: 2rem;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.service-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--primary);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(14, 165, 233, 0.2);
}

.icon-container {
    width: 64px;
    height: 64px;
    border-radius: 1rem;
    background: rgba(14, 165, 233, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(14, 165, 233, 0.2);
    transition: all 0.5s ease;
}

.service-card:hover .icon-container {
    background: var(--primary);
    transform: rotate(10deg);
}

.service-card:hover .icon-container i {
    color: var(--text-main);!important;
}

.service-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 1rem;
}

.service-description {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
}

.tech-tag {
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.75rem;
    color: var(--text-muted);
    transition: all 0.3s ease;
}

.service-card:hover .tech-tag {
    border-color: var(--secondary);
    color: var(--text-main);
}    


/* Progress Line Styles */
#progress-line {
    transition: width 0.1s ease-out;
    border-radius: 0 2px 2px 0;
}

/* Smooth appearance */
#progress-line {
    opacity: 0.9;
}

#progress-line:hover {
    opacity: 1;
    height: 2px;
}

/* Mobile responsiveness */
@media (max-width: 768px) {
    #progress-line {
        height: 2px;
    }
}

/* Portfolio Section Animations */
.portfolio-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
}

.portfolio-item.animate-in {
    opacity: 1;
    transform: translateY(0);
}

/* Section visibility classes */
.section-hidden {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease;
}

.section-visible {
    opacity: 1;
    transform: translateY(0);
}

/* Theme transition rules */
body, .glass, .navbar, .portfolio-card, .service-card, .skill-card, .timeline-card, .certification-card, p, h1, h2, h3, h4, h5, h6, span, a, div {
    transition: background-color 0.4s ease, border-color 0.4s ease, color 0.4s ease, box-shadow 0.4s ease !important;
}

.gradient-bg {
    background: linear-gradient(-45deg, var(--gradient-1), var(--gradient-2), var(--gradient-1), var(--gradient-3));
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
